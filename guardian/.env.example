# ============================================================
# Guardian Agent — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#
# For the CHAT INTERFACE (Vercel), you only need the Required section.
# For GITHUB REPO MANAGEMENT (Fly.io), you also need the Optional section.
# ============================================================

# --- REQUIRED (chat interface) ---

# Supabase
SUPABASE_URL=https://effzofflphvbyvcenvly.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # Dashboard → Settings → API → service_role
SUPABASE_ANON_KEY=                  # Dashboard → Settings → API → anon (public)

# Anthropic (chat responses + memory extraction)
ANTHROPIC_API_KEY=

# OpenAI (embeddings only)
OPENAI_API_KEY=

# --- OPTIONAL (GitHub repo management — not needed for chat) ---

# GitHub App (only if Guardian manages a GitHub repo)
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# GITHUB_INSTALLATION_ID=

# Inngest (scheduled agents: Extractor, Consolidator, Curator, Scribe)
# Without Inngest, memory extraction happens inline during chat.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- CONFIG ---

GUARDIAN_REPO=leonardrknight/ai-continuity-framework
LOG_LEVEL=info
PORT=3000
